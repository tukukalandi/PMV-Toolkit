rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - email: string (required)
    //   - role: string (required, 'staff' or 'admin')
    //   - uid: string (required)
    //
    // Collection: tickets
    // Document ID: ticketId
    // Fields:
    //   - email: string (required)
    //   - circleUserId: string (required)
    //   - divisionUserId: string (required)
    //   - deliveryStaffUserId: string (required)
    //   - issueType: string (required)
    //   - subType: string (required)
    //   - mobileNumber: string (required)
    //   - applicationNumber: string (required)
    //   - artisanMobileNumber: string (required)
    //   - description: string (required)
    //   - createdAt: timestamp (required)
    //   - uid: string (required)
    //   - status: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         ((request.auth.token.email == "tukukalandi@gmail.com" || request.auth.token.email == "dnk005892@gmail.com") && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'uid']) &&
             data.email is string &&
             data.role in ['staff', 'admin'] &&
             data.uid == request.auth.uid;
    }

    function isValidTicket(data) {
      return data.keys().hasAll(['email', 'deliveryStaffUserId', 'issueType', 'subType', 'createdAt']) &&
             data.email is string &&
             data.deliveryStaffUserId is string &&
             data.issueType in ['Login Issue', 'Before Redemption', 'Redemption', 'After Redemption'] &&
             data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'staff' || isAdmin());
      allow update: if isAuthenticated() && isAdmin() && isValidUser(request.resource.data);
    }

    match /tickets/{ticketId} {
      allow read: if true;
      allow create: if isValidTicket(request.resource.data);
      allow update: if isAuthenticated() && isAdmin();
      allow delete: if isAuthenticated() && isAdmin();
    }
  }
}
